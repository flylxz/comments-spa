{
  "name": "comments-spa",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "frontend",
      "backend",
      "packages/shared"
    ],
    "catalog": {
      "zod": "^3.25.76",
      "typescript": "^5.8.3",
      "@types/node": "^24.0.13"
    }
  },
  "scripts": {
    "dev:frontend": "bun --filter @comments-spa/shared build && bun --filter comments-spa-frontend dev",
    "dev:backend": "bun --filter @comments-spa/shared build && bun --filter comments-spa-backend dev",
    "build": "bun --filter @comments-spa/shared build && bun --filter comments-spa-frontend build && bun --filter comments-spa-backend build",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched",
      "jscpd"
    ],
    "*.json": [
      "biome format --write"
    ]
  },
  "trustedDependencies": [
    "@prisma/client",
    "prisma",
    "sharp"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "lint-staged": "^16.1.2"
  }
}
